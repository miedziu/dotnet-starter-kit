{
    "omnisharp.dotnetPath": "/home/jarvis/.dotnet",
    "omnisharp.sdkPath": "/home/jarvis/.dotnet/sdk/10.0.102",
    "omnisharp.useModernNet": true,
    "editor.formatOnSave": true,
    "files.exclude": {
        "**/bin": true,
        "**/obj": true,
        "**/node_modules": true,
        "**/wwwroot": true,
        "**/Dockerfile": true,
        "**/Properties": true,
        "**/.git": true,
        "**/.gitignore": true,
        //"**/.editorconfig": true,
        "**/.vs": true,
        //"**/*.json": true,
        "**/*.http": true,
        "**/*.user": true,
        //"**/.*": true,
        ".vscode/e*": true,
        ".vscode/l*": true,
        ".vscode/t*": true,
        //".vscode/*": true,
        ".github": true,
        "**/*.md": true, //
        "**/*.min.*": true,
        ".agents": true
    },
    "diffEditor.renderGutterMenu": false,
    "diffEditor.renderIndicators": true,
    "diffEditor.renderMarginRevertIcon": true,
    "diffEditor.renderSideBySide": true,
    "diffEditor.useInlineViewWhenSpaceIsLimited": true,
    "diffEditor.wordWrap": "inherit",
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },
    "editor.defaultFormatter": "ms-dotnettools.csharp",
    "editor.formatOnSaveMode": "modifications",
    "editor.formatOnType": true,
    "editor.formatOnPaste": true,
    "gitlens.hovers.changesDiff": "line",
    "gitlens.views.openChangesInMultiDiffEditor": true,
    "mergeEditor.diffAlgorithm": "advanced",
    "scm.diffDecorations": "all",
    "[typescript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
}